# Ghostty config — ~/.config/ghostty/config
# Mirrors the iTerm2 profile "dro" (colors + padding) and keeps the useful
# quality-of-life keys from the prior seed. Updated 2026-06-26.
# Source: ~/Library/Preferences/com.googlecode.iterm2.plist
# Reload after edits: Cmd+Shift+, (or quit/relaunch). Validate: ghostty +show-config
# Lines marked [+] are improvements beyond a literal 1:1 copy.

# ── Font ────────────────────────────────────────────────────────────────
# iTerm2: "FiraCodeNFM-Reg 13" (FiraCode Nerd Font Mono, Regular, 13pt).
# Ligatures (calt) and Nerd Font glyphs are on automatically.
font-family = FiraCode Nerd Font Mono
font-size = 13
# iTerm2 "Use Bright Bold" = on → bold text uses the bright ANSI palette.
# (Ghostty's `bold-is-bright` is deprecated; `bold-color = bright` replaces it.)
bold-color = bright
# [+] Thicken glyphs slightly — dark text reads crisper on the light bg.
font-thicken = true
# iTerm2 had one FiraCode stylistic feature enabled; pick a set if you want
# its alternate glyphs (e.g. ss05 = letterlike "@"):
# font-feature = ss05

# ── Colors — your custom iTerm2 LIGHT scheme ────────────────────────────
# (Replaces the prior Catppuccin auto-theme so this matches iTerm2 exactly.
#  To go back to system-following themes instead, delete this block and use:
#    theme = light:Catppuccin Latte,dark:Catppuccin Mocha )
background = #fafafa
foreground = #101010

cursor-color = #000000
cursor-text  = #ffffff
cursor-style = block
# iTerm2 "Blinking Cursor" = off (Ghostty: comments must be on their own line)
cursor-style-blink = false

selection-background = #b3d7ff
selection-foreground = #000000

# 16-color ANSI palette (iTerm2 "Ansi 0..15 Color")
palette = 0=#14191e
palette = 1=#b43c2a
palette = 2=#00c200
palette = 3=#c7c400
palette = 4=#2744c7
palette = 5=#c040be
palette = 6=#00c5c7
palette = 7=#c7c7c7
palette = 8=#686868
palette = 9=#dd7975
palette = 10=#58e790
palette = 11=#ece100
palette = 12=#a7abf2
palette = 13=#e17ee1
palette = 14=#60fdff
palette = 15=#ffffff

# [+] Render Ghostty's own chrome (titlebar/menus) light to match the scheme,
#     instead of following macOS dark mode.
window-theme = light

# ── Window / padding ────────────────────────────────────────────────────
# iTerm2 global margins: TerminalMargin=25 (x), TerminalVMargin=25 (y).
window-padding-x = 25
window-padding-y = 25
# [+] Keep padding even on all sides when the window isn't an exact cell
#     multiple (iTerm2 lets the extra pixels pile up bottom-right).
window-padding-balance = true
# Initial window size — iTerm2 opened at 80 columns × 25 rows.
window-width = 80
window-height = 25
# iTerm2 was fully opaque (Transparency 0, Blur off) — Ghostty defaults match.
# background-opacity = 1
# background-blur = false

# ── Keys / behavior (kept from prior config) ────────────────────────────
# Send Option as Alt/Meta so Claude Code's Option+Enter / Option+P work
# (mirrors iTerm2 "Esc+").
macos-option-as-alt = true
# Bring windows back after quit/restart (Ghostty has no restore by default).
window-save-state = always
# Hide the mouse pointer while typing.
mouse-hide-while-typing = true
# Generous scrollback for long agent transcripts (iTerm2 was capped at 1000).
scrollback-limit = 100000000

# Optional: global dropdown "quick terminal" — uncomment for a hotkey.
# keybind = global:cmd+grave_accent=toggle_quick_terminal
