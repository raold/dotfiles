# Backup files (prevent accumulation in version control)
*.backup*
*.bak
*.save
*.orig
*~

# Rofi theme assets (large, unused - reinstall from rofi-collection if needed)
.config/rofi/images/
.config/rofi/launchers/
.config/rofi/powermenu/
.config/rofi/applets/

# Editor swap files
*.swp
*.swo
.*.swp

# Python bytecode
__pycache__/
*.pyc

# Tool artifacts
.flagged
.serena/
project.yml

# macOS
.DS_Store

# --- secret-exclusions (macOS tracking) — never commit ---
**/settings.local.json
**/secrets.zsh
**/secrets.zsh.age
*key.txt
.age/
macos/.claude/settings.json
